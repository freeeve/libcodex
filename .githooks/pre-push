#!/bin/sh
# Pre-push hook mirroring the static checks of CI's build job (gofmt, vet,
# staticcheck at CI's pinned version, then the test suite without -race), so a
# push that would fail CI is stopped locally instead. The test suite covers CI's
# interop job too, but only when the third-party parsers it needs are importable,
# so the hook probes for them and warns when they are missing rather than letting
# a silent skip read as a pass. It then smoke-fuzzes every Fuzz* target in the
# packages this push changes — fuzzing lives here rather than in CI so runs
# accumulate the persistent local corpus (GOCACHE/fuzz) instead of restarting
# from seeds. Enable once per clone:
#
#	git config core.hooksPath .githooks
#
# INTEROP_PYTHON picks the interpreter for the interop stage (default python3);
# PREPUSH_FUZZTIME overrides the per-target fuzz budget (default 10s);
# PREPUSH_SKIP_FUZZ=1 skips the fuzz stage. Bypass everything for an
# emergency push: git push --no-verify
set -e
cd "$(git rev-parse --show-toplevel)"

# Collect the Go files this push changes before anything else touches stdin:
# git feeds the hook one "<local ref> <local sha> <remote ref> <remote sha>"
# line per ref being pushed.
zero=0000000000000000000000000000000000000000
changed=""
while read -r _ local_sha _ remote_sha; do
	if [ "$local_sha" = "$zero" ]; then
		continue # ref deletion: nothing to check
	fi
	if [ "$remote_sha" = "$zero" ]; then
		range="origin/main...$local_sha" # new ref: diff against main's merge base
	else
		range="$remote_sha..$local_sha"
	fi
	changed="$changed
$(git diff --name-only "$range" -- '*.go' 2>/dev/null || true)"
done

echo "pre-push: gofmt -s"
fmt=$(gofmt -s -l .)
if [ -n "$fmt" ]; then
	echo "pre-push: gofmt -s needed on:" >&2
	echo "$fmt" >&2
	exit 1
fi

echo "pre-push: go vet"
go vet ./...

echo "pre-push: staticcheck"
go run honnef.co/go/tools/cmd/staticcheck@v0.7.0 ./...

# CI's second job reads our generated output back with pymarc, rdflib,
# bibtexparser and rispy. `go test ./...` below runs that same TestInterop, but
# it t.Skipf's when it cannot import the parsers, and a skipped test still
# prints ok -- so the suite reports success having checked nothing. Probe the
# parsers first with the same interpreter TestInterop will use, and say which of
# the two happened. A silent skip here once let an interop regression ship in
# five releases.
interop_py="${INTEROP_PYTHON:-python3}"
interop_note=""
if "$interop_py" testdata/interop.py check >/dev/null 2>&1; then
	echo "pre-push: interop parsers present ($interop_py); go test will exercise them"
else
	interop_note=" (interop SKIPPED)"
	echo "pre-push: interop will SKIP -- $interop_py cannot import the third-party parsers:" >&2
	"$interop_py" testdata/interop.py check 2>&1 | sed 's/^/pre-push:   /' >&2 || true
	echo "pre-push:   CI runs this job regardless. To run it here:" >&2
	echo "pre-push:   pip install pymarc rdflib bibtexparser rispy  (or set INTEROP_PYTHON)" >&2
fi

echo "pre-push: go test"
go test ./...

dirs=$(printf '%s\n' "$changed" | grep -v '^$' | while read -r f; do dirname "$f"; done | sort -u)
if [ -n "${PREPUSH_SKIP_FUZZ:-}" ]; then
	dirs=""
fi
fuzztime="${PREPUSH_FUZZTIME:-10s}"
rc=0
for dir in $dirs; do
	[ -d "$dir" ] || continue                        # package removed by this push
	go list "./$dir" >/dev/null 2>&1 || continue     # skip other modules (e.g. bench/)
	for f in $(grep -lE '^func Fuzz' "$dir"/*_test.go 2>/dev/null); do
		for fn in $(grep -oE '^func Fuzz[A-Za-z0-9_]+' "$f" | awk '{print $2}'); do
			echo "pre-push: fuzz ./$dir $fn ($fuzztime)"
			go test "./$dir" -run='^$' -fuzz="^${fn}\$" -fuzztime="$fuzztime" || rc=1
		done
	done
done
if [ "$rc" -ne 0 ]; then
	echo "pre-push: fuzz smoke failed (reproducer written to testdata/fuzz/ if it was a real finding)" >&2
	exit 1
fi

echo "pre-push: all checks passed$interop_note"
